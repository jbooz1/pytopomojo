{
  "name": "pytopomojo-devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    }
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "mounts": [
    "source=pytopomojo-pip-cache,target=/home/vscode/.cache/pip,type=volume",
    // AWS credentials for Claude Code (optional)
    "source=${localWorkspaceFolder}/.devcontainer/.aws,target=/home/vscode/.aws,type=bind",
    // Claude Code data (sessions, history, todos, etc.)
    "source=pytopomojo-claude,target=/home/vscode/.claude,type=volume",
    // TopoMojo API source
    "source=pytopomojo-topomojo-api,target=/mnt/topomojo-api,type=volume",
    // Shell history
    "source=pytopomojo-shell-history,target=/home/vscode/.history,type=volume"
  ],
  "containerEnv": {
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "CLAUDE_CODE_USE_BEDROCK": "1", // vars for Claude Code using Amazon Bedrock
    "AWS_REGION": "us-east-1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "us.anthropic.claude-haiku-4-5-20251001-v1:0"
  },
  "postCreateCommand": [
    "bash",
    "-lc",
    ".devcontainer/postcreate.sh"
  ],
  "postStartCommand": [
    "bash",
    "-lc",
    "ENV_FILE=$(pwd)/.devcontainer/.env; grep -qF \"$ENV_FILE\" ~/.zshenv 2>/dev/null || echo \"[ -f \\\"$ENV_FILE\\\" ] && source \\\"$ENV_FILE\\\"\" >> ~/.zshenv"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-python.isort",
        "esbenp.prettier-vscode",
        "Anthropic.claude-code",
        "AmazonWebServices.aws-toolkit-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.insertFinalNewline": true,
        "files.eol": "\n",
        "files.trimTrailingWhitespace": true,
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.envFile": "${workspaceFolder}/.devcontainer/.env",
        "python.analysis.typeCheckingMode": "basic",
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      }
    }
  },
  "runArgs": [
    "--init"
  ]
}
